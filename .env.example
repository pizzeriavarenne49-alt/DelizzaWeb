# Firebase (WLHORIZON) — Priority 1 data source
# Credentials from the WLHORIZON Firebase project (service account)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
# WL_APP_ID=app_cfb23cce-7aa1-475f-b5de-804f441b865e

# Firebase Client SDK (browser)
# NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
# NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx

# Firebase App Check — reCAPTCHA Enterprise site key (production)
# Leave unset in local development: App Check debug mode will be enabled automatically.
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-enterprise-site-key

# ────────────────────────────────────────────────────────────────────────────
# STRIPE PAYMENT INTEGRATION
# ────────────────────────────────────────────────────────────────────────────

# Stripe public key (safe to expose to frontend)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_XXXXX

# Stripe secret key (SERVER ONLY — never expose to frontend)
STRIPE_SECRET_KEY=sk_test_XXXXX

# Stripe webhook signing secret (from Dashboard → Webhooks)
# Used to verify webhook signatures in /api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_test_XXXXX

# ────────────────────────────────────────────────────────────────────────────
# CLOUD FUNCTIONS
# ────────────────────────────────────────────────────────────────────────────

# The following Cloud Functions MUST be deployed in WLHORIZON Firebase:
#   - validateAndCalculateOrder(items[]) → returns server-calculated amounts
#   - createOrder(items[], amounts, fulfillment) → creates draft order
#   - createPaymentIntent(orderId) → creates Stripe PI, returns clientSecret
#   - getAvailableSlots(appId, date) → returns TimeSlot availability
#
# Region: europe-west1
# See WLHORIZON repository for Cloud Functions source code.

# ────────────────────────────────────────────────────────────────────────────
# DIRECTUS CMS — Priority 2 data source (fallback when Firebase is not configured)
# ────────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_DIRECTUS_URL=http://localhost:8055

# Optional: static API token (only needed if Public role is not configured)
# DIRECTUS_STATIC_TOKEN=your-token-here

# ────────────────────────────────────────────────────────────────────────────
# ANALYTICS
# ────────────────────────────────────────────────────────────────────────────

# Google Analytics 4 measurement ID
# NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# ────────────────────────────────────────────────────────────────────────────
# MODE "OUVERTURE PROCHAINE"
# ────────────────────────────────────────────────────────────────────────────

# true  → overlay actif, site bloqué
# false → site normal (retirer ou mettre false pour ouvrir le site)
# NEXT_PUBLIC_COMING_SOON=true
